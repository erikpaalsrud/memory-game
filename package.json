{
  "name": "memory-game",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "client",
    "scripts"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "build": "npm run build -w client",
    "start": "NODE_ENV=production npx tsx server/src/index.ts",
    "generate-cards": "npx tsx scripts/generate-cards.ts",
    "generate-placeholders": "npx tsx scripts/generate-placeholders.ts",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  }
}
